# .env.p1p.example - Template for p1p secret references
# Copy to .env.p1p and update locker/item names for your project
# This file is SAFE TO COMMIT - it only contains references, not actual secrets

# =============================================================================
# CONTRACT DEPLOYMENT
# =============================================================================

# Private key for contract deployment (EVM format: 0x...)
PRIVATE_KEY=p1p://<your-locker>/contracts/customFields.private_key

# Deployer wallet address (for reference/verification)
DEPLOYER_ADDRESS=p1p://<your-locker>/contracts/customFields.deployer_address

# =============================================================================
# NETWORK CONFIGURATION
# =============================================================================

# Paseo Testnet (default for development)
PASEO_RPC_URL=https://eth-rpc-testnet.polkadot.io
PASEO_CHAIN_ID=420420417

# Mainnet (uncomment for production)
# MAINNET_RPC_URL=https://polkadot-asset-hub-eth-rpc.polkadot.io
# MAINNET_CHAIN_ID=TBD

# Previewnet (no tokens needed, ephemeral)
# PREVIEWNET_RPC_URL=https://previewnet.substrate.dev/eth-rpc

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================

# Contract addresses (update after deployment)
VITE_CONTRACT_ADDRESS=p1p://<your-locker>/paseo-contracts/customFields.main_contract

# WalletConnect (optional)
VITE_WALLETCONNECT_PROJECT_ID=p1p://<your-locker>/walletconnect/customFields.project_id

# Bulletin Chain
VITE_BULLETIN_ENDPOINT=wss://paseo-bulletin-rpc.polkadot.io

# =============================================================================
# DOTNS DEPLOYMENT (read separately, not via p1p run)
# =============================================================================

# Note: DotNS mnemonic is read via:
#   export DOTNS_MNEMONIC=$(p1p read "p1p://<your-locker>/dotns/customFields.mnemonic" -n)
#
# Not included here because dotns CLI uses -m flag, not environment variables

# =============================================================================
# USAGE
# =============================================================================

# 1. Sign in to p1p:
#    p1p signin --mnemonic
#
# 2. Run commands with secrets injected:
#    p1p run --env-file .env.p1p -- forge script script/Deploy.s.sol --broadcast
#
# 3. For dotns CLI (export separately):
#    export DOTNS_MNEMONIC=$(p1p read "p1p://<your-locker>/dotns/customFields.mnemonic" -n)
#    bun run src/cli/index.ts bulletin upload ./dist -m "$DOTNS_MNEMONIC"
