# Polkadot Asset Hub EVM Configuration
# Copy this to .env and fill in your values
# NEVER commit .env to version control!

# Deployer private key (with 0x prefix)
PRIVATE_KEY=0x...

# Admin address for contract ownership
ADMIN_ADDRESS=0x...

# RPC URLs
PASEO_RPC_URL=https://paseo-asset-hub-eth-rpc.polkadot.io
POLKADOT_RPC_URL=https://polkadot-asset-hub-eth-rpc.polkadot.io

# Optional: Token addresses (if your project uses tokens)
# HOLLAR_ADDRESS=0x...
